<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:fillViewport="true"
        android:background="#F6F6F6">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- Top Bar -->
            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Home"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content" />

                <ImageView
                    android:id="@+id/navNotification"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="16dp"
                    android:src="@drawable/ic_notification" />

                <ImageView
                    android:id="@+id/navSettings"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="16dp"
                    android:src="@drawable/ic_settings" />
            </LinearLayout>

            <!-- Greeting -->
            <TextView
                android:text="Hi, Sasha!"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"/>

            <TextView
                android:text="Your security dashboard"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <!-- SOS Button -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:gravity="center"
                android:layout_marginTop="40dp">

                <TextView
                    android:id="@+id/btnSOS"
                    android:layout_width="250dp"
                    android:layout_height="250dp"
                    android:gravity="bottom|center_horizontal"
                    android:paddingBottom="30dp"
                    android:text="SOS"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/sos_default"
                    android:layout_centerInParent="true" />
            </RelativeLayout>

            <!-- Stop SOS Button (hidden by default, shown during active SOS) -->
            <Button
                android:id="@+id/btnStopSOS"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="40dp"
                android:text="⬛ STOP SOS TRACKING"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF5252"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:layout_width="170dp"
                    android:id="@+id/navMap"
                    android:layout_height="60dp"
                    android:text="Map"
                    android:textAllCaps="false"
                    android:textSize="20sp"/>


                <Button
                    android:layout_width="200dp"
                    android:id="@+id/btn_shareLocation"
                    android:layout_height="60dp"
                    android:text="Share location"
                    android:textAllCaps="false"
                    android:textSize="20sp"/>

            </LinearLayout>

            <Space android:layout_width="60dp" android:layout_height="20dp" />



            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <Button
                    android:id="@+id/btn_reportLocation"
                    android:layout_width="170dp"
                    android:layout_height="60dp"
                    android:text="Report location"
                    android:textAllCaps="false"
                    android:textSize="20sp"
                    android:onClick="showMyToast"/>


                <Button
                    android:layout_width="200dp"
                    android:layout_height="60dp"
                    android:id="@+id/btn_safeplace"
                    android:text="Find safespace"
                    android:paddingLeft="20dp"
                    android:padding="6dp"
                    android:textAllCaps="false"
                    android:textSize="20sp"/>

            </LinearLayout>





        </LinearLayout>


    </ScrollView>


</RelativeLayout>
