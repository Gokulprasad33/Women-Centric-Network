<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:background="#F6F6F6">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <!-- Top Bar -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Home"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />

            <ImageView
                android:id="@+id/navNotification"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_notification" />

            <ImageView
                android:id="@+id/navSettings"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_settings" />
        </LinearLayout>

        <!-- Greeting -->
        <TextView
            android:id="@+id/tvGreeting"
            android:text="Hi there!"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"/>

        <TextView
            android:text="Your security dashboard"
            android:textSize="14sp"
            android:layout_marginTop="2dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#666666"/>

        <!-- Friend Status Row (Compose) -->
        <androidx.compose.ui.platform.ComposeView
            android:id="@+id/friendStatusComposeView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <!-- Latest Alert Banner (Compose) — single alert, auto-hides after 10 min -->
        <androidx.compose.ui.platform.ComposeView
            android:id="@+id/latestAlertComposeView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <!-- SOS Button -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:minHeight="240dp">

            <TextView
                android:id="@+id/btnSOS"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:gravity="bottom|center_horizontal"
                android:paddingBottom="30dp"
                android:text="SOS"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/sos_default"
                android:layout_centerInParent="true" />
        </RelativeLayout>

        <!-- Stop SOS Button (hidden by default, shown during active SOS) -->
        <Button
            android:id="@+id/btnStopSOS"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="32dp"
            android:text="STOP SOS TRACKING"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF5252"
            android:visibility="gone" />

        <!-- Alert Network Button -->
        <Button
            android:id="@+id/btnAlertNetwork"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="16dp"
            android:text="Alert Nearby Users"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:backgroundTint="#FF9800" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <Button
                android:layout_width="0dp"
                android:layout_weight="1"
                android:id="@+id/navMap"
                android:layout_height="48dp"
                android:layout_marginEnd="4dp"
                android:text="Map"
                android:textAllCaps="false"
                android:textSize="14sp"/>

            <Button
                android:layout_width="0dp"
                android:layout_weight="1"
                android:id="@+id/btn_shareLocation"
                android:layout_height="48dp"
                android:layout_marginStart="4dp"
                android:text="Share Location"
                android:textAllCaps="false"
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp">

            <Button
                android:id="@+id/btn_reportLocation"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:layout_marginEnd="4dp"
                android:text="Report"
                android:textAllCaps="false"
                android:textSize="14sp"/>

            <Button
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:layout_marginStart="4dp"
                android:id="@+id/btn_safeplace"
                android:text="Safe Space"
                android:textAllCaps="false"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Nearby Helpers Section (Compose) -->
        <androidx.compose.ui.platform.ComposeView
            android:id="@+id/nearbyHelpersComposeView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</ScrollView>

