<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">


<fragment
        android:id="@+id/homeFragment"
        android:name="com.example.womencentricnetwork.View.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_homeFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
        <action
            android:id="@+id/action_homeFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
    <action
        android:id="@+id/action_homeFragment_to_notificationFragment"
        app:destination="@id/notificationFragment" />
    <action
        android:id="@+id/action_homeFragment_to_settingsFragment"
        app:destination="@id/settingsFragment" />
    <action
        android:id="@+id/action_homeFragment_to_mapFragment"
        app:destination="@id/mapFragment" />
    <action
        android:id="@+id/action_homeFragment_to_communityFragment"
        app:destination="@id/communityFragment" />
</fragment>

    <fragment
        android:id="@+id/chatFragment"
        android:name="com.example.womencentricnetwork.View.ChatScreen"
        android:label="Chat"
        tools:layout="@layout/fragment_chat" >
        <action
            android:id="@+id/action_chatFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_chatFragment_to_communityFragment"
            app:destination="@id/communityFragment" />
        <action
            android:id="@+id/action_chatFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.womencentricnetwork.View.ProfileScreen"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" >
        <action
            android:id="@+id/action_profileFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_profileFragment_to_communityFragment"
            app:destination="@id/communityFragment" />
        <action
            android:id="@+id/action_profileFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
    </fragment>

    <fragment
        android:id="@+id/communityFragment"
        android:name="com.example.womencentricnetwork.View.CommunityScreen"
        android:label="Community"
        tools:layout="@layout/fragment_community" >
        <action
            android:id="@+id/action_communityFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_communityFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
        <action
            android:id="@+id/action_communityFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
    </fragment>

    <fragment
        android:id="@+id/notificationFragment"
        android:name="com.example.womencentricnetwork.View.NotificationScreen"
        android:label="Profile"
        tools:layout="@layout/fragment_notification" />
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.womencentricnetwork.View.SettingsScreen"
        android:label="Settings" />

    <fragment
        android:id="@+id/mapFragment"
        android:name="com.example.womencentricnetwork.View.MapFragment"
        android:label="Map"
        tools:layout="@layout/fragment_map"/>

</navigation>
